{
    "version": 2,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": { "distDir": "dist" }
        },
        { "src": "backend/**/*.py", "use": "@vercel/python" }
    ],
    "routes": [
        { "src": "/_/backend/(.*)", "dest": "/backend/$1" },
        { "src": "/(.*)", "dest": "/frontend/$1" }
    ],
    "functions": {
        "backend/*.py": { "runtime": "python3.11" }
    }
}